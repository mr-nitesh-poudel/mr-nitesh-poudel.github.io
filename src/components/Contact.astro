---
---
<section id="contact" class="contact">
  <div class="contact-inner">
    <div class="contact-text reveal">
      <div class="section-header">
        <span class="section-num">04</span>
        <h2 class="section-title">Let's Talk</h2>
      </div>
      <p class="contact-desc">
        Whether you need a mobile app built from the ground up, a performant backend system,
        or just want to talk tech — my inbox is open.
      </p>
      <a href="mailto:ace@example.com" class="contact-email">
        ace@example.com
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M3 9h12M9 3l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <div class="social-links">
        <a href="https://github.com" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          GitHub
        </a>
        <a href="https://twitter.com" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          Twitter
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="contact-form-wrap reveal" style="transition-delay: 0.15s">
      <form class="contact-form" id="contact-form">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Tell me about your project..." required></textarea>
        </div>
        <button type="submit" class="form-submit">
          <span>Send Message</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<footer class="footer">
  <span class="footer-name">ace. — built with Astro</span>
  <span class="footer-copy">© 2025</span>
</footer>

<style>
  .contact {
    padding: 7rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .contact-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.85;
    margin-bottom: 2rem;
  }

  .contact-email {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
    margin-bottom: 2.5rem;
    transition: color 0.2s, border-color 0.2s, gap 0.2s;
  }
  .contact-email:hover {
    color: var(--accent);
    border-color: var(--accent);
    gap: 0.85rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .social-links a:hover {
    color: var(--accent);
  }

  /* Form */
  .contact-form-wrap {
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  input, textarea {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.9rem;
    border-radius: 2px;
    outline: none;
    resize: none;
    transition: border-color 0.2s;
  }
  input::placeholder, textarea::placeholder {
    color: rgba(30, 25, 20, 0.3);
  }
  input:focus, textarea:focus {
    border-color: rgba(200, 134, 26, 0.5);
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 0.5rem;
    padding: 0.9rem 2rem;
    background: var(--accent);
    color: var(--bg);
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    border-radius: 2px;
    transition: opacity 0.2s, transform 0.2s;
  }
  .form-submit:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--border);
    padding: 1.75rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-name, .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-transform: lowercase;
  }

  @media (max-width: 900px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 700px) {
    .contact {
      padding: 5rem 1.5rem;
    }
    .footer {
      padding: 1.5rem;
    }
  }
</style>
