---
// under-construction.astro
// Drop this in src/pages/ or use as a layout replacement
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Under Construction — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg:        #0d0d0b;
      --surface:   #131310;
      --border:    #2a2a24;
      --amber:     #f5a623;
      --amber-dim: #a06a12;
      --text:      #e8e4d8;
      --muted:     #6b6757;
      --serif:     'DM Serif Display', Georgia, serif;
      --mono:      'JetBrains Mono', 'Courier New', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      font-size: 14px;
      overflow: hidden;
    }

    /* ── noise grain overlay ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 999;
      opacity: 0.6;
    }

    /* ── amber scanlines ── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 3px,
        rgba(245, 166, 35, 0.015) 3px,
        rgba(245, 166, 35, 0.015) 4px
      );
      pointer-events: none;
      z-index: 998;
    }

    /* ── layout ── */
    .stage {
      height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      grid-template-columns: 1fr;
      padding: 2rem 2.5rem;
      max-width: 900px;
      margin: 0 auto;
    }

    /* ── header bar ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1rem;
      opacity: 0;
      animation: fadeUp 0.6s ease forwards;
      animation-delay: 0.1s;
    }

    .header-sig {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .header-sig span {
      color: var(--amber);
    }

    .status-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .status-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--amber);
      animation: pulse 2s ease-in-out infinite;
    }

    /* ── main content ── */
    .main {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
    }

    .label {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--amber-dim);
      opacity: 0;
      animation: fadeUp 0.5s ease forwards;
      animation-delay: 0.3s;
    }

    .headline {
      font-family: var(--serif);
      font-size: clamp(3rem, 8vw, 6.5rem);
      line-height: 0.95;
      letter-spacing: -0.01em;
      color: var(--text);
      opacity: 0;
      animation: fadeUp 0.7s ease forwards;
      animation-delay: 0.45s;
    }

    .headline em {
      font-style: italic;
      color: var(--amber);
    }

    .divider-line {
      width: 0;
      height: 1px;
      background: linear-gradient(to right, var(--amber), transparent);
      animation: expand 0.8s ease forwards;
      animation-delay: 0.8s;
    }

    .body-copy {
      max-width: 480px;
      line-height: 1.75;
      color: var(--muted);
      font-size: 13px;
      font-weight: 300;
      opacity: 0;
      animation: fadeUp 0.6s ease forwards;
      animation-delay: 0.95s;
    }

    .body-copy strong {
      color: var(--text);
      font-weight: 400;
    }

    /* ── progress bar ── */
    .progress-wrap {
      opacity: 0;
      animation: fadeUp 0.5s ease forwards;
      animation-delay: 1.1s;
    }

    .progress-label {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .progress-label span:last-child {
      color: var(--amber);
    }

    .progress-track {
      width: 100%;
      height: 2px;
      background: var(--border);
      position: relative;
      overflow: hidden;
    }

    .progress-fill {
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      width: 0;
      background: var(--amber);
      animation: fillBar 2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: 1.4s;
    }

    .progress-glow {
      position: absolute;
      right: 0;
      top: -3px;
      width: 12px;
      height: 8px;
      background: radial-gradient(ellipse, rgba(245,166,35,0.7), transparent 70%);
    }

    /* ── footer ── */
    .footer {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      border-top: 1px solid var(--border);
      padding-top: 1rem;
      opacity: 0;
      animation: fadeUp 0.5s ease forwards;
      animation-delay: 1.3s;
    }

    .footer-note {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.6;
    }

    .footer-note a {
      color: var(--amber);
      text-decoration: none;
      border-bottom: 1px solid var(--amber-dim);
      transition: border-color 0.2s;
    }

    .footer-note a:hover {
      border-color: var(--amber);
    }

    .terminal-cursor {
      display: inline-block;
      width: 9px;
      height: 1.1em;
      background: var(--amber);
      vertical-align: middle;
      margin-left: 3px;
      animation: blink 1.1s step-end infinite;
    }

    /* ── decorative side number ── */
    .side-number {
      position: fixed;
      right: 2.5rem;
      top: 50%;
      transform: translateY(-50%) rotate(90deg);
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--border);
      white-space: nowrap;
      pointer-events: none;
    }

    /* ── corner bracket decoration ── */
    .bracket-tl,
    .bracket-br {
      position: fixed;
      width: 24px;
      height: 24px;
      pointer-events: none;
      opacity: 0.35;
    }

    .bracket-tl {
      top: 1.5rem;
      left: 1.5rem;
      border-top: 1px solid var(--amber);
      border-left: 1px solid var(--amber);
    }

    .bracket-br {
      bottom: 1.5rem;
      right: 1.5rem;
      border-bottom: 1px solid var(--amber);
      border-right: 1px solid var(--amber);
    }

    /* ── keyframes ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes expand {
      to { width: 180px; }
    }

    @keyframes fillBar {
      to { width: 73%; }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.4; transform: scale(0.75); }
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }

    /* ── responsive ── */
    @media (max-width: 600px) {
      .stage { padding: 1.5rem; }
      .side-number { display: none; }
    }
  </style>
</head>
<body>

  <div class="bracket-tl"></div>
  <div class="bracket-br"></div>
  <p class="side-number">Nitesh Poudel — Portfolio 2025</p>

  <div class="stage">

    <header class="header">
      <span class="header-sig">niteshpoudel<span>.dev</span></span>
      <div class="status-pill">
        <span class="status-dot"></span>
        Building in progress
      </div>
    </header>

    <main class="main">
      <p class="label">// under construction</p>

      <h1 class="headline">
        Something<br/>
        <em>good</em><br/>
        is coming.
      </h1>

      <div class="divider-line"></div>

      <p class="body-copy">
        This page is currently being crafted with care.<br/>
        <strong>Check back soon</strong> — or reach out directly
        if you need to get in touch.
      </p>

      <div class="progress-wrap">
        <div class="progress-label">
          <span>Build progress</span>
          <span>73%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill">
            <div class="progress-glow"></div>
          </div>
        </div>
      </div>
    </main>

    <footer class="footer">
      <div class="footer-note">
        Questions? <a href="mailto:hello@niteshpoudel.dev">contact@niteshpoudel.com</a><br/>
        <a href="https://github.com/mr-nitesh-poudel" target="_blank" rel="noopener">github.com/mr-nitesh-poudel</a>
      </div>
      <div style="font-size: 11px; color: var(--muted);">
        <span id="clock"></span><span class="terminal-cursor"></span>
      </div>
    </footer>

  </div>

  <script>
  </script>

</body>
</html>